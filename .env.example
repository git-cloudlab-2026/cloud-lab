# Exemple de variables d'environnement
# Ne pas mettre de vraies valeurs ici.

# Backend Express
PORT=3000
NODE_ENV=development

# Authentification
# mock = developpement/demo sans Azure ; oidc = Microsoft Entra ID reel
AUTH_MODE=mock
SESSION_SECRET=change-me-with-a-long-random-value
SESSION_COOKIE_NAME=cloud_lab.sid
SESSION_MAX_AGE_MS=28800000

# Microsoft Entra ID / OIDC
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=change-me
AZURE_REDIRECT_URI=http://localhost:3000/api/v1/auth/callback
AZURE_SCOPES=openid profile email User.Read

# PostgreSQL local de developpement uniquement
DATABASE_URL=postgres://cloud_lab_dev:cloud_lab_dev_password@localhost:5432/cloud_lab
PGHOST=localhost
PGPORT=5432
PGUSER=cloud_lab_dev
PGPASSWORD=cloud_lab_dev_password
PGDATABASE=cloud_lab

OS_AUTH_URL=https://example-openstack-auth-url
OS_PROJECT_NAME=example-project
OS_USERNAME=example-user
OS_PASSWORD=change-me
OS_REGION_NAME=dc3-a
