# Exemple de variables d'environnement.
# Ne jamais mettre de vrais secrets dans ce fichier.

# Backend FastAPI
ENVIRONMENT=development
API_PORT=8000
FRONTEND_PORT=8080
CORS_ORIGINS=["http://localhost:8000","http://localhost:8080","http://localhost:3000","http://localhost:5173","null"]

# Authentification
# mock = developpement local sans Azure
# oidc = Microsoft Entra ID reel
AUTH_MODE=mock
SESSION_SECRET=change-me-with-a-long-random-value
JWT_SECRET=change-me-with-a-long-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=8

# Microsoft Entra ID / OIDC
# Redirect URI a declarer dans Azure App Registration:
# http://localhost:8000/api/v1/auth/callback
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=change-me
AZURE_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback
AZURE_SCOPES=openid profile email User.Read GroupMember.Read.All

# Mapping groupes Entra ID -> roles applicatifs
# Remplacer par les vrais Object IDs des groupes Microsoft.
ENTRA_ADMIN_GROUP_ID=00000000-0000-0000-0000-000000000001
ENTRA_VALIDATOR_GROUP_ID=00000000-0000-0000-0000-000000000002
ENTRA_TEACHER_GROUP_ID=00000000-0000-0000-0000-000000000003
ENTRA_STUDENT_E1_GROUP_ID=00000000-0000-0000-0000-000000000101
ENTRA_STUDENT_E2_GROUP_ID=00000000-0000-0000-0000-000000000102
ENTRA_STUDENT_E3_GROUP_ID=00000000-0000-0000-0000-000000000103
ENTRA_STUDENT_E4_GROUP_ID=00000000-0000-0000-0000-000000000104
ENTRA_STUDENT_E5_GROUP_ID=00000000-0000-0000-0000-000000000105
OIDC_AUTO_CREATE_STUDENTS=true

# PostgreSQL local de developpement uniquement
DATABASE_URL=postgresql+asyncpg://cloud_lab_dev:cloud_lab_dev_password@localhost:5432/cloud_lab
# SQLite peut etre utilise pour des tests isoles si le backend est adapte:
# DATABASE_URL=sqlite+aiosqlite:///./cloud_lab_dev.sqlite3
POSTGRES_USER=cloud_lab_dev
POSTGRES_PASSWORD=cloud_lab_dev_password
POSTGRES_DB=cloud_lab
PGHOST=localhost
PGPORT=5432
PGUSER=cloud_lab_dev
PGPASSWORD=cloud_lab_dev_password
PGDATABASE=cloud_lab

# OpenStack / Infomaniak - valeurs fictives
OS_AUTH_URL=https://api.pub1.infomaniak.cloud/identity/v3
OS_PROJECT_NAME=Projet-ALJ
OS_USERNAME=PCU-XXXX
OS_PASSWORD=change-me
OS_REGION_NAME=dc4-a
OS_EXTERNAL_NETWORK_ID=change-me-external-network-id
OS_EXTERNAL_NETWORK_NAME=
SSH_PUBLIC_KEY_PATH=~/.ssh/id_ed25519.pub

# Provisioner applicatif.
# mock = mode demo/app Docker sans creation cloud
# terraform = a activer seulement quand le provisioning direct est volontairement valide
PROVISIONER_MODE=mock
MOCK_TERRAFORM_CREATE_DELAY_SECONDS=0.2
MOCK_TERRAFORM_DESTROY_DELAY_SECONDS=0.1
LIFECYCLE_SCHEDULER_ENABLED=true
LIFECYCLE_SCHEDULER_INTERVAL_SECONDS=3600

# Provisionnement reel Terraform / Infomaniak
TERRAFORM_BINARY=terraform
TERRAFORM_MODULE_DIR=/app/infrastructure
TERRAFORM_WORK_DIR=/app/.terraform-runs
TERRAFORM_OPENSTACK_CLOUD_NAME=openstack
TERRAFORM_REGION=dc4-a
TERRAFORM_PROJECT_PREFIX=cloud-lab
TERRAFORM_NETWORK_CIDR=10.42.0.0/24
TERRAFORM_EXTERNAL_NETWORK_NAME=ext-floating1
TERRAFORM_ALLOWED_SSH_CIDRS=["0.0.0.0/0"]
TERRAFORM_DEFAULT_FLAVOR_NAME=a1-ram2-disk20-perf1
TERRAFORM_IMAGE_NAME=Ubuntu 24.04 LTS Noble Numbat
TERRAFORM_ASSIGN_FLOATING_IP=false
TERRAFORM_SSH_PUBLIC_KEY=
TERRAFORM_SSH_PUBLIC_KEY_PATH=

# Emails SMTP optionnels.
# Si EMAIL_NOTIFICATIONS_ENABLED=false, les notifications restent en base uniquement.
EMAIL_NOTIFICATIONS_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Cloud Lab
SMTP_USE_TLS=true
